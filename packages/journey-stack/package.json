{
  "name": "journey-stack",
  "version": "0.1.1",
  "description": "Headless React navigation library that tracks user journeys as chapters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepack": "cp ../../README.md ."
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "react",
    "navigation",
    "breadcrumbs",
    "journey",
    "chapters",
    "headless"
  ],
  "license": "MIT",
  "author": "Simon Hobman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shobman/journey-stack.git",
    "directory": "packages/journey-stack"
  },
  "homepage": "https://shobman.github.io/journey-stack/"
}
